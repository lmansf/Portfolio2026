{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "trailingSlash": false,
  "cleanUrls": false,
  "headers": [
    {
      "source": "/(.*).html",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, max-age=0, must-revalidate"
        }
      ]
    },
    {
      "source": "/",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, max-age=0, must-revalidate"
        }
      ]
    },
    {
      "source": "/(work|pipeline|fraud|shop|resume|feedback)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, max-age=0, must-revalidate"
        }
      ]
    },
    {
      "source": "/(.*).(css|js|json|txt|xml)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    },
    {
      "source": "/(.*).(avif|png|jpg|jpeg|svg|webp|ico|pdf|woff|woff2|ttf)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=604800, stale-while-revalidate=86400"
        }
      ]
    }
  ],
  "redirects": [
    {
      "source": "/blog",
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/blog.html",
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/projects",
      "destination": "/work",
      "permanent": true
    },
    {
      "source": "/projects.html",
      "destination": "/work.html",
      "permanent": true
    },
    {
      "source": "/architecture",
      "destination": "/pipeline",
      "permanent": true
    },
    {
      "source": "/architecture.html",
      "destination": "/pipeline.html",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/",
      "destination": "/index.html"
    },
    {
      "source": "/work",
      "destination": "/work.html"
    },
    {
      "source": "/pipeline",
      "destination": "/pipeline.html"
    },
    {
      "source": "/shop",
      "destination": "/shop.html"
    },
    {
      "source": "/resume",
      "destination": "/resume.html"
    },
    {
      "source": "/feedback",
      "destination": "/feedback.html"
    },
    {
      "source": "/fraud",
      "destination": "/fraud.html"
    }
  ]
}
